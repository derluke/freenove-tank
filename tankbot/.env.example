# Copy to .env and fill in your values
# Taskfile and the Python/Elixir code read these

# Raspberry Pi SSH access (used by Taskfile)
PI_HOST=raspberrypi.local
PI_USER=pi
PI_DIR=/home/pi/tankbot

# Robot WebSocket URL (used by Phoenix web app and vision engine)
ROBOT_URL=ws://raspberrypi.local:9000
